# === 必須: クラウドAPI鍵 ===
# 頭脳（Claude）
ANTHROPIC_API_KEY=
# 耳と声（OpenAI STT / TTS）
OPENAI_API_KEY=

# === Phase 1以降で使用 ===
# IPカメラのRTSP URL（直接指定．Qwatch例: rtsp://user:pass@IP:25112/ipcam_h264.sdp）
CAMERA_RTSP_URL=
# または Qwatch APIでRTSP URLを自動解決（CAMERA_RTSP_URL未設定時．docs/qwatch-api/ 参照）
CAMERA_HOST=
CAMERA_USER=
CAMERA_PASS=

# === 外部連携（秘書ツール）===
# 研究文献ディレクトリ（ローカル参照．PDFは pdftotext で抽出: brew install poppler）
PAPERS_DIR=
# Notion 連携トークン（my-integrations で作成・ページをコネクト．未設定でNotionツール無効）
NOTION_TOKEN=

# === モデル設定 ===
# 頭脳。低遅延重視は sonnet、込み入った依頼は opus
BRAIN_MODEL=claude-sonnet-4-6
# 短い相槌・即応用の軽量モデル（2段構え）
FAST_MODEL=claude-haiku-4-5-20251001
# 応答1回の最大トークン. render_uiでHTMLを生成すると長くなるため十分に確保する
# （小さすぎるとツール入力が途中で切れて壊れ, 応答失敗の原因になる）
BRAIN_MAX_TOKENS=8192

# === パーソナリティ（初期値．会話で「君の名前を〇〇にして」等と頼めば変更でき, ローカルDBに永続化）===
# アシスタントの名前と読み
ASSISTANT_NAME=谺
ASSISTANT_READING=こだま
# 主人（オーナー）の名前・読み・呼び方
OWNER_NAME=油谷知岐
OWNER_READING=あぶらたに ともき
OWNER_HONORIFIC=油谷さん
# 音声認識（フォールバックのバッチSTT；常時STTが起動するまでの保険）
STT_MODEL=gpt-4o-transcribe
# 完全ローカルの常時ストリーミングSTT（whisper.cpp / whisper-server 常駐）.
# 1=有効（ウェイクワード不要で常時聴取・クラウド送信なし）/ 0=無効（ウェイクワード方式）
LOCAL_STREAMING=1
# final=確定用の最高精度モデル / partial=途中表示用の高速モデル（whisper.cpp ggml）
WHISPER_FINAL_MODEL=./models/ggml-large-v3.bin
WHISPER_PARTIAL_MODEL=./models/ggml-large-v3-turbo.bin
# whisper-server のスレッド数 / 待受ポート（既定で被りにくい番号）
WHISPER_SERVER_THREADS=6
WHISPER_SERVER_PORT_FINAL=53121
WHISPER_SERVER_PORT_PARTIAL=53122
# 擬似ストリーミングの途中再デコード間隔ms（小さいほど“伸び”が滑らか・CPU増）
PARTIAL_INTERVAL_MS=600
# 応答ゲート: 常時聞き取った発話のうち, 谺へ明確に向けられたものだけに応答する（1=有効/0=全部応答）.
# 複数人の会話・独り言・谺宛でない雑談には黙って聞くだけ（履歴には残す）.
ADDRESSING_GATE=1
# 応答時にClaudeへ渡す履歴範囲（直近メッセージ数）. ゲートが内容から適切な数を判定しクランプ.
CONTEXT_WINDOW_DEFAULT=16
CONTEXT_WINDOW_MIN=4
CONTEXT_WINDOW_MAX=100
# 発話中の中断フレーズ（音声での停止）. これらを聞き取ると読み上げを止める.
STOP_PHRASES=ストップ,すとっぷ,止まって,止まれ,やめて,黙って,stop
# 一般バージイン: 谺の発話中にフレーズに依らず話し始めたら即中断して傾聴へ（1=有効/0=無効）.
# ※エコーキャンセル無しのため, スピーカー使用で谺が自己中断する場合は 0 にするか
#   BARGE_THRESHOLD_MULT を上げる（ヘッドホン推奨）. 逆に自分の声で止まらないなら値を下げる.
BARGE_IN=1
BARGE_THRESHOLD_MULT=2.2
BARGE_START_FRAMES=4
# Web検索（Anthropic公式のサーバサイドWeb検索ツール．追加APIキー不要・Anthropic課金に計上）.
# 最新情報・時事・事実確認などローカル資料に無い質問でClaudeが検索して引用付きで答える.
WEB_SEARCH=1
WEB_SEARCH_MAX_USES=5
# 音声合成
TTS_MODEL=gpt-4o-mini-tts
# 音声合成エンジン: say=ローカル(macOS say) / openai=クラウド
TTS_ENGINE=openai
# 話者（OpenAI TTS voice）
TTS_VOICE=alloy
# ローカル say の話者（`say -v '?'` で一覧．既定 Kyoko）
TTS_SAY_VOICE=Kyoko
# 音声再生速度（1.0=等速．音程は保持．sayは素で約340字/分→0.9で約300字/分）
TTS_SPEED=1.0
# 読み上げチャンクの最小文字数（大きいほど文をまとめ滑らか／小さいほど初動が速い）
TTS_MIN_CHARS=60
# 最初のチャンクだけに使う小さい閾値（最初の一文が確定した瞬間に話し始める）
TTS_FIRST_MIN_CHARS=6

# === 自己改修（谺が自分のソースコードを承認制で書き換え・再起動する）===
# 無効化する場合は false（ソースツリー＋node_modules がある環境でのみ有効になる）
SELF_MOD=true

# === 音声I/O（ffmpeg / ffplay が必要: brew install ffmpeg）===
# マイク取り込みの有効化
ENABLE_MIC=true
# macOS avfoundation の入力デバイス（":0" = 既定の音声入力．`ffmpeg -f avfoundation -list_devices true -i ""` で確認）
AUDIO_INPUT_DEVICE=:0
# 発話区間検出（エネルギーVAD）の感度
VAD_THRESHOLD=0.018
# 無音がこのフレーム数続くと発話終端とみなす（小さいほど応答が速い／途中で切れやすい．32ms単位）
VAD_SILENCE_FRAMES=25
# 発話開始前を何フレームさかのぼって取り込むか（語頭の欠け防止．32ms単位）
VAD_PREROLL_FRAMES=8

# === ウェイクワード（ローカル Whisper, 任意）===
# whisper.cpp の CLI（macOS: `brew install whisper-cpp` で whisper-cli が入る）
WHISPER_BIN=whisper-cli
# ggml モデルのパス（例: ./models/ggml-small.bin）．未設定だとウェイクワード無効→手動ウェイク
WHISPER_MODEL=
# 文字起こしの言語
WHISPER_LANGUAGE=ja
# 呼びかけフレーズ（カンマ区切り．文字起こし結果にいずれかを含むと起動）
# Whisperは「こだま」を文脈で 谺/木霊/木魂/小玉/コダマ 等に変換するため同音異字を網羅する
WAKEWORD_PHRASES=谺,こだま,コダマ,木霊,木魂,小玉,児玉,kodama
# ウェイクワード切り出しの発話上限フレーム（512サンプル/32ms × 150 ≒ 4.8秒）
WAKE_MAX_FRAMES=150
# ウェイクワードの無音判定（短いほど「こだま」検知が速い．32ms単位）
WAKE_SILENCE_FRAMES=12
# 傾聴モードの無入力タイムアウト（ms）
LISTEN_TIMEOUT_MS=8000
# 返答後に自動で傾聴へ（「こだま」無しで続けて話せる．true/false）
FOLLOWUP_LISTEN=true

# === 話者識別（声による個人識別, 完全ローカル）===
# 発話ごとに話者埋め込み（sherpa-onnx）を計算し, 登録済みの声と照合して
# 発話へ（話者: 名前）タグを付ける. 未登録の声は「ゲストA」等の仮ラベルになり,
# 谺が名前を尋ねて enroll_speaker で正式登録する（＝声を覚える）. 1/0
SPEAKER_ID=1
# 話者埋め込みモデル（ONNX）. 既定は 3D-Speaker CAM++（約28MB）:
# https://github.com/k2-fsa/sherpa-onnx/releases/tag/speaker-recongition-models
SPEAKER_MODEL=./models/3dspeaker_speech_campplus_sv_zh_en_16k-common_advanced.onnx
# 本人判定のコサイン類似度閾値（高いほど厳格）
SPEAKER_THRESHOLD=0.45
# 識別に用いる最小発話長（秒）. これ未満の短い発話は識別しない
SPEAKER_MIN_SEC=0.8
# 1話者あたり保持する声サンプル数の上限
SPEAKER_MAX_SAMPLES=12

# === ローカルサーバ設定 ===
# 会話履歴・音声・DBの格納先（全部ローカルに持つ）
DATA_DIR=./data
# Web UI / API のポート（一般的なポートとの競合を避けた専用番号）
PORT=52525

# === 語彙学習・定期要約（§15.1 / §15.2） ===
# 認識ヒント（whisperのpromptへ載せる登録語彙）の上限件数
STT_HINT_MAX_TERMS=64
# 会話から自動抽出した語彙の初期weight（user明示登録=1より低くしてヒント上位を譲る）
AUTO_TERM_WEIGHT=0.5
# 会話を話題ごとに要約するジョブの実行間隔（ms）
DIGEST_INTERVAL_MS=180000
# 1回の要約で読む未要約メッセージの上限
DIGEST_BATCH_MAX=120
# この件数未満なら要約をスキップ（細切れ要約を避ける）
DIGEST_MIN_MESSAGES=6
